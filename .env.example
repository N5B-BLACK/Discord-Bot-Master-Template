# انسخ هذا الملف باسم .env واملأ القيم الحقيقية
# لا ترفع ملف .env نفسه على GitHub أبداً (موجود بالـ .gitignore أصلاً)

# --- أساسي ---
DISCORD_TOKEN=
BOT_PREFIX=!
GUILD_ID=

# --- قاعدة البيانات (MongoDB Atlas - مجاني) ---
# رولات وقنوات كل سيرفر صارت تنضبط عن طريق أمر /setup داخل ديسكورد نفسه،
# وتتخزن هون - ما عاد تحتاج تحط IDs يدوي بهذا الملف.
MONGODB_URI=

# --- الذكاء الاصطناعي (عبر OpenRouter) ---
OPENROUTER_API_KEY=
AI_MODEL=openrouter/free

# --- تخصيص الهوية ---
BOT_NAME=المساعد
WELCOME_MESSAGE=أهلاً فيك {member} بسيرفر {guild}! 🎉
EMBED_COLOR=0x5865F2
